# Copy this file to `.env` and fill in your key. `.env` is gitignored (never committed).
# The LLM GL-mapping backend (llm_gl_mapping.py) reads these automatically.
# Without any key it falls back to the keyless heuristic, so the demo always runs.

# Preferred backend:
OPENAI_API_KEY=sk-your-openai-key-here

# Optional alternative backend:
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides:
# ALTIS_OPENAI_MODEL=gpt-4o-mini
# ALTIS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
