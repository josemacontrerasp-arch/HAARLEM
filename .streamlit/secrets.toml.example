# Copy to `.streamlit/secrets.toml` for LOCAL runs, OR paste these lines into the
# Streamlit Community Cloud "Secrets" box for the deployed app.
# The real secrets.toml is gitignored — never commit it.

# Gate the deployed app behind a password (judges get this password).
# If omitted, the app is OPEN (no password) — fine for local/dev.
APP_PASSWORD = "choose-a-strong-password"

# LLM GL-mapping backend. Without a key the panel uses the keyless heuristic.
OPENAI_API_KEY = "sk-..."
# ANTHROPIC_API_KEY = "sk-ant-..."
